#!/usr/bin/env zsh
# claude-secretmode — leave no trace: an ephemeral Claude Code session on macOS.
#
# Boots Claude Code with CLAUDE_CONFIG_DIR pointed at a RAM disk, so the session
# transcript / prompt history / file snapshots / claude.json live only in memory
# and evaporate on exit (hdiutil detach). Your real ~/.claude is never touched.
# Authentication is inherited from the macOS keychain ("Claude Code-credentials").
# Recording/observability hooks (claude-mem, etc.) are disabled for the session.
#
# Usage:  claude-secretmode [args passed straight to `claude`]
#         CLAUDE_SECRETMODE_RAM_MB=2048 claude-secretmode --model opus
#         CLAUDE_SECRETMODE_DROP_HOOKS="my-logger.sh,other.sh" claude-secretmode
#
# Requires: macOS, Claude Code (npm i -g @anthropic-ai/claude-code) logged in.
set -euo pipefail
umask 077          # token/config files are owner-only from the moment of creation

SRC="${CLAUDE_CONFIG_DIR_REAL:-$HOME/.claude}"
HOME_JSON="$HOME/.claude.json"

# ── locate the claude binary (avoid nvm lazy wrappers / shell functions) ──
CLAUDE_BIN=""
for c in "$HOME"/.nvm/versions/node/*/bin/claude(N) \
         /opt/homebrew/bin/claude /usr/local/bin/claude "$HOME"/.local/bin/claude; do
  [[ -x "$c" ]] && { CLAUDE_BIN="$c"; break; }
done
[[ -x "$CLAUDE_BIN" ]] || CLAUDE_BIN="$(command -v claude 2>/dev/null || true)"
[[ -x "$CLAUDE_BIN" ]] || {
  print -u2 "claude-secretmode: 'claude' not found. Install it:  npm install -g @anthropic-ai/claude-code"
  exit 1
}
# Claude's launcher resolves itself via PATH; ensure its dir is on PATH.
export PATH="${CLAUDE_BIN:h}:$PATH"

# recency helper shipped alongside this script (resolve symlinks: npm bin, csm alias)
VERDICT_HELPER="${0:A:h}/secretmode-token-verdict.py"

RAMSIZE_MB=${CLAUDE_SECRETMODE_RAM_MB:-1024}
SECTORS=$(( RAMSIZE_MB * 2048 ))   # 1 sector = 512 bytes

# ── 0. reap orphan RAM disks from a previous crash/HUP (skip live siblings) ──
setopt local_options null_glob
for mp in "$SRC"/tmp/secretmode-*; do
  opid="${mp##*-}"
  # numeric-PID check via POSIX regex (avoids EXTENDED_GLOB dependency, off by
  # default in non-interactive zsh). If the owning process is alive, leave it.
  if [[ "$opid" =~ ^[0-9]+$ ]] && kill -0 "$opid" 2>/dev/null; then
    continue                                   # a live concurrent session — leave it
  fi
  if mount 2>/dev/null | grep -qF " on ${mp} ("; then
    odev="$(mount | grep -F " on ${mp} (" | awk '{print $1}')"
    umount "$mp" 2>/dev/null || diskutil unmount force "$mp" >/dev/null 2>&1 || true
    [[ -n "$odev" ]] && { hdiutil detach "$odev" >/dev/null 2>&1 || hdiutil detach -force "$odev" >/dev/null 2>&1; } || true
  fi
  mount | grep -qF " on ${mp} (" || rm -rf "$mp" 2>/dev/null || true
done

# ── 1. create the RAM disk ──
DEV="$(hdiutil attach -nomount ram://$SECTORS)"
DEV="${DEV%%[[:space:]]*}"          # first field (device path) only
GHOST="$SRC/tmp/secretmode-$$"      # mountpoint (shell dir; contents live in RAM)

# Register cleanup the instant the device exists, so a newfs/mount failure
# can't leak wired RAM.
cleanup() {
  cd / 2>/dev/null || true
  [[ -n "${TOKENSYNC_PID:-}" ]] && kill "$TOKENSYNC_PID" 2>/dev/null || true
  # the RAM disk may be briefly busy from claude's child processes → force fallback
  umount "$GHOST" 2>/dev/null || diskutil unmount force "$GHOST" >/dev/null 2>&1 || true
  hdiutil detach "$DEV" >/dev/null 2>&1 || hdiutil detach -force "$DEV" >/dev/null 2>&1 || true
  # only rm -rf once truly unmounted (rmdir can't clear leftover files)
  mount | grep -qF " on ${GHOST} (" || rm -rf "$GHOST" 2>/dev/null || true
}
trap cleanup EXIT INT TERM HUP   # HUP: closing the terminal is the most common orphan cause

newfs_hfs -v secretmode "$DEV" >/dev/null
mkdir -p "$GHOST"
mount -t hfs "$DEV" "$GHOST"

# verify the mount is actually live before writing the token (else it hits real disk)
if ! mount | grep -qF " on ${GHOST} ("; then
  print -u2 "claude-secretmode: RAM disk mount verification failed — aborting."
  exit 1
fi

# ── 2. selectively populate the isolated config dir ──
# 2a. auth: keychain → .credentials.json (token never printed; umask 077 → 600)
security find-generic-password -w -s "Claude Code-credentials" > "$GHOST/.credentials.json" 2>/dev/null \
  || { print -u2 "claude-secretmode: could not read keychain login (Claude Code-credentials). Log in with 'claude' first."; exit 1; }
chmod 600 "$GHOST/.credentials.json"

# 2b. account metadata .claude.json (wipe past project traces, keep account/mcpServers)
python3 - "$HOME_JSON" "$GHOST/.claude.json" <<'PY'
import json, sys
src, dst = sys.argv[1], sys.argv[2]
try:
    with open(src) as fh:
        d = json.load(fh)
except (FileNotFoundError, json.JSONDecodeError):
    d = {}
d['projects'] = {}
d['numStartups'] = 0
with open(dst, 'w', encoding='utf-8') as fh:
    json.dump(d, fh, ensure_ascii=False)
PY

# 2c. settings.json: disable recording/observability hooks + claude-mem plugin.
#     Recording hooks are matched by keyword; add more via CLAUDE_SECRETMODE_DROP_HOOKS
#     (comma list), or set CLAUDE_SECRETMODE_STRIP_ALL_HOOKS=1 to drop every hook.
#     Hooks that survive (non-recording) are counted and warned about below, since
#     a keyword denylist can't know every user's custom logging hook.
SURVIVING_HOOKS="$(python3 - "$SRC/settings.json" "$GHOST/settings.json" "${CLAUDE_SECRETMODE_DROP_HOOKS:-}" "${CLAUDE_SECRETMODE_STRIP_ALL_HOOKS:-}" <<'PY'
import json, sys
src, dst, extra, stripall = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]
try:
    with open(src) as fh:
        d = json.load(fh)
except (FileNotFoundError, json.JSONDecodeError):
    d = {}
extra_names = {x.strip() for x in extra.split(',') if x.strip()}
KW = ('claude-mem', 'caveman', 'observ', 'telemetry', 'analytics', 'mem-search')
strip_all = stripall not in ('', '0', 'false', 'False')
def is_recording(cmd):
    lc = cmd.lower()
    return any(k in lc for k in KW) or any(n in cmd for n in extra_names)
h = d.get('hooks', {})
survivors = []
for ev in list(h):
    kept = []
    for m in h[ev]:
        hooks = []
        for hk in m.get('hooks', []):
            cmd = hk.get('command', '')
            if strip_all or is_recording(cmd):
                continue
            hooks.append(hk); survivors.append(cmd)
        if hooks:
            m['hooks'] = hooks; kept.append(m)
    if kept:
        h[ev] = kept
    else:
        del h[ev]
ep = d.get('enabledPlugins', {})
for k in list(ep):
    if any(t in k.lower() for t in ('claude-mem', 'caveman', 'observ')):
        ep[k] = False
with open(dst, 'w', encoding='utf-8') as fh:
    json.dump(d, fh, ensure_ascii=False)
print(len(survivors))
PY
)"
if [[ -n "$SURVIVING_HOOKS" && "$SURVIVING_HOOKS" != "0" ]]; then
  print -P "%F{yellow}⚠%f ${SURVIVING_HOOKS} non-recording hook(s) still active this session. Set %F{cyan}CLAUDE_SECRETMODE_STRIP_ALL_HOOKS=1%f to disable all, or list them in CLAUDE_SECRETMODE_DROP_HOOKS."
fi

# 2d. symlink read-only assets (CLAUDE.md, instructions, hooks scripts, skills, agents…)
for f in CLAUDE.md instructions.md rules references agents commands skills hooks patterns plans config; do
  if [[ -e "$SRC/$f" ]]; then ln -s "$SRC/$f" "$GHOST/$f"; fi
done

# 2e. plugins: symlink (code/marketplace metadata is shared, non-sensitive),
#     copy small mutable state files, keep data/ isolated (empty).
mkdir -p "$GHOST/plugins"
for sub in cache repos marketplaces; do
  if [[ -e "$SRC/plugins/$sub" ]]; then ln -s "$SRC/plugins/$sub" "$GHOST/plugins/$sub"; fi
done
for f in installed_plugins.json config.json known_marketplaces.json plugin-catalog-cache.json blocklist.json; do
  if [[ -f "$SRC/plugins/$f" ]]; then cp "$SRC/plugins/$f" "$GHOST/plugins/"; fi
done
mkdir -p "$GHOST/plugins/data"

# ── 3. token sync daemon ──
# A concurrently-running normal `claude` may refresh the OAuth token; rotation then
# invalidates this session's snapshot and logs it out. Mirror the keychain's latest
# token into the RAM file so the secret session keeps up.
# Bound to: (a) parent alive (kill -0) so an orphaned daemon dies with its session,
#           (b) RAM disk still mounted so it can never write the token to real disk.
MAIN_PID=$$
(
  while kill -0 "$MAIN_PID" 2>/dev/null && mount | grep -qF " on ${GHOST} ("; do
    sleep 2
    mount | grep -qF " on ${GHOST} (" || break   # re-check after sleep: never write to plain disk
    new="$(security find-generic-password -w -s "Claude Code-credentials" 2>/dev/null)" || continue
    [[ -n "$new" ]] || continue
    cur="$(cat "$GHOST/.credentials.json" 2>/dev/null)"
    if [[ "$new" != "$cur" ]]; then
      # Adopt the keychain token ONLY when it is strictly newer than this session's
      # (larger claudeAiOauth.expiresAt). Without this guard the daemon would roll a
      # token this session just refreshed itself back to the keychain's older copy,
      # logging the session out. Verdict is computed by the unit-tested sibling
      # helper; token values are passed via env so they never appear in argv.
      if [[ "$(SECRETMODE_NEW="$new" SECRETMODE_CUR="$cur" python3 "$VERDICT_HELPER" 2>/dev/null)" == "UPDATE" ]]; then
        printf '%s' "$new" > "$GHOST/.credentials.json.tmp" 2>/dev/null \
          && mv -f "$GHOST/.credentials.json.tmp" "$GHOST/.credentials.json" 2>/dev/null
      fi
    fi
  done
) </dev/null >/dev/null 2>&1 &
TOKENSYNC_PID=$!
disown 2>/dev/null || true

# ── 4. run ──
export CLAUDE_SECRETMODE=1
export CLAUDE_CONFIG_DIR="$GHOST"
print -P "%F{magenta}🕶  secretmode%f — RAM disk %F{cyan}${DEV}%f (${RAMSIZE_MB}MB). Transcript & history stay in RAM, not disk; evaporates on exit."
( exec "$CLAUDE_BIN" "$@" )
